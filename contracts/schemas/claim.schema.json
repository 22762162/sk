{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sanjian/contracts/claim.schema.json",
  "title": "运行态论断结构(claim,DESIGN V3.0 §3.4)",
  "type": "object",
  "required": ["claim_id", "claim_type", "claim", "evidence", "support_status", "confidence"],
  "properties": {
    "claim_id": { "type": "string" },
    "claim_type": {
      "type": "string",
      "enum": ["computed_fact", "school_rule", "model_synthesis", "reflective_prompt"],
      "$comment": "computed_fact 只能由 L1 注入并携带引擎签名字段,模型不得自行输出此类型"
    },
    "origin": {
      "type": ["string", "null"],
      "$comment": "computed_fact 必填 engine-paipan;其余类型为产生该论断的辩手槽位"
    },
    "engine_version": { "type": ["string", "null"] },
    "calculation_hash": { "type": ["string", "null"] },
    "school": { "type": ["string", "null"] },
    "claim": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "source_id", "condition_match", "entailment"],
        "properties": {
          "rule_id": { "type": "string" },
          "source_id": { "type": "string" },
          "source_locator": { "type": ["string", "null"] },
          "condition_match": { "type": "boolean" },
          "entailment": { "type": "string", "enum": ["direct", "partial", "indirect"] }
        },
        "additionalProperties": false
      }
    },
    "counterevidence": { "type": "array", "items": { "type": "object" } },
    "support_status": {
      "type": "string",
      "enum": ["supported", "partial", "unsupported", "disputed"]
    },
    "confidence": {
      "type": "object",
      "required": ["confidence_label", "confidence_basis"],
      "properties": {
        "confidence_label": { "type": "string", "enum": ["low", "medium", "high"] },
        "confidence_basis": {
          "type": "string",
          "enum": ["rule_match", "source_support", "synthesis"]
        },
        "calibration_version": { "type": ["string", "null"] }
      },
      "additionalProperties": false,
      "$comment": "禁用自由字符串与未校准数值"
    },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false,
  "$comment": "验收分层:L1 computed_fact 可讨论计算正确性;其余只讨论规则忠实度、一致性与来源。无 evidence 且非 reflective_prompt 的论断计入 unsupported_claim_rate。"
}
